{
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=DotNetNuke;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "System": "Warning"
    }
  },
  "Jwt": {
    "Secret": "THIS_IS_A_DEVELOPMENT_ONLY_SECRET_KEY_DO_NOT_USE_IN_PRODUCTION_MINIMUM_32_CHARS_REQUIRED",
    "Issuer": "DnnMigration",
    "Audience": "DnnMigration",
    "ExpirationMinutes": 120,
    "RefreshTokenExpirationDays": 7
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/dnnmigration-dev-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}{NewLine}{Message:lj}{NewLine}{Exception}",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "DnnMigration.Api",
      "Environment": "Development"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "http://localhost:4201",
      "http://127.0.0.1:4200"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "PATCH",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Content-Type",
      "Authorization",
      "X-Requested-With",
      "Accept",
      "Origin",
      "X-Portal-Id"
    ],
    "ExposedHeaders": [
      "X-Pagination",
      "X-Total-Count",
      "Location"
    ],
    "AllowCredentials": true
  },
  "SwaggerDoc": {
    "Enabled": true,
    "Title": "DNN Migration API - Development",
    "Description": "Development environment API documentation for the DotNetNuke 4.x to ASP.NET Core 8 migration project. This API provides RESTful endpoints for Portal, Module, User, Role, and Tab management, replacing the legacy WebForms-based admin interfaces.",
    "Version": "v1",
    "ContactName": "Development Team",
    "ContactEmail": "dev@dnnmigration.local",
    "EnableAnnotations": true,
    "EnableXmlComments": true,
    "IncludeSchemas": true
  },
  "AllowedHosts": "*",
  "DetailedErrors": true,
  "EnableSensitiveDataLogging": true,
  "Database": {
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 3,
    "MaxRetryDelaySeconds": 5,
    "CommandTimeoutSeconds": 60,
    "EnableDetailedErrors": true,
    "EnableSensitiveDataLogging": true
  },
  "HealthChecks": {
    "Enabled": true,
    "DbHealthCheckEnabled": true,
    "DetailedOutput": true
  },
  "FeatureFlags": {
    "EnableSwagger": true,
    "EnableDetailedExceptions": true,
    "EnableRequestLogging": true,
    "EnableResponseCaching": false,
    "EnableRateLimiting": false
  }
}
